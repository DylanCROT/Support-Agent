# MCP server credentials — copy this file to .env and fill in real values.
# .env is gitignored.
#
# These are the same tokens used by the po-assistant repo. If you've already
# generated them there, just copy the values across.

# Bitbucket Cloud — read-only PAT for vatit-admin workspace
# Generate at: https://bitbucket.org/account/settings/app-passwords/
BITBUCKET_TOKEN=your_bitbucket_pat_here
BITBUCKET_WORKSPACE=vatit-admin

# GitHub — Salesforce team repos via GitHub MCP (stdio)
# Generate at: https://github.com/settings/tokens (repo:read scope is enough)
GITHUB_PERSONAL_ACCESS_TOKEN=your_github_pat_here
